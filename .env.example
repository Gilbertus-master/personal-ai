# === Postgres ===
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=gilbertus
POSTGRES_USER=gilbertus
POSTGRES_PASSWORD=REPLACE_ME

# === Anthropic (used for extraction) ===
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_EXTRACTION_MODEL=claude-sonnet-4-5

# === Microsoft Graph API (V2 — corporate email/Teams sync) ===
MS_GRAPH_TENANT_ID=common
MS_GRAPH_CLIENT_ID=REPLACE_ME
MS_GRAPH_SCOPES=Mail.Read Chat.Read Calendars.Read offline_access
