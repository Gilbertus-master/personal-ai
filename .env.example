# === App ===
APP_NAME=Gilbertus Albans
APP_VERSION=0.1.0
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000

# === OpenAI ===
OPENAI_API_KEY=sk-proj-REPLACE_ME

# === Embeddings ===
EMBEDDING_MODEL=text-embedding-3-large

# === Qdrant ===
QDRANT_URL=http://127.0.0.1:6333
