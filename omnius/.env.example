# Omnius REF — Environment Variables
# Copy to .env and fill in values

# === PostgreSQL ===
OMNIUS_POSTGRES_HOST=omnius-db
OMNIUS_POSTGRES_PORT=5432
OMNIUS_POSTGRES_DB=omnius_ref
OMNIUS_POSTGRES_USER=omnius
OMNIUS_POSTGRES_PASSWORD=CHANGE_ME

# === Tenant config ===
OMNIUS_TENANT=ref
OMNIUS_COMPANY_NAME=Respect Energy Fuels

# === Azure AD (SSO + Graph API) ===
OMNIUS_AZURE_TENANT_ID=
OMNIUS_AZURE_CLIENT_ID=
OMNIUS_GRAPH_CLIENT_ID=
OMNIUS_GRAPH_CLIENT_SECRET=

# === Teams Bot ===
OMNIUS_TEAMS_APP_ID=
OMNIUS_TEAMS_APP_SECRET=

# === LLM ===
OMNIUS_LLM_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=

# === Dev mode (set to 1 for local dev — bypasses Azure AD auth) ===
OMNIUS_DEV_AUTH=0
